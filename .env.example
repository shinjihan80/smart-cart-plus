# NEMOA 환경변수 샘플
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채워 넣으세요.
# .env.local 은 .gitignore 에 이미 포함되어 있어 커밋되지 않습니다.

# ─────────────────────────────────────────────────────────
# 필수
# ─────────────────────────────────────────────────────────

# Google Gemini API 키
# 발급: https://aistudio.google.com/app/apikey
# AI 기능(Vision, Parser, Nutrition, URL, Style)이 이 키에 의존합니다.
# 무료 티어: gemini-2.0-flash 기준 RPM 15·RPD 1,500 (베이직 단계 충분)
GEMINI_API_KEY=AIza

# ─────────────────────────────────────────────────────────
# 선택 (베이직에서는 모두 비워둬도 동작)
# ─────────────────────────────────────────────────────────

# 사이트 공개 URL — SEO · sitemap · OG 이미지 생성에 사용
# 비워두면 http://localhost:3000 로 폴백
# NEXT_PUBLIC_SITE_URL=https://nemoa.app

# 익명 사용 통계 엔드포인트 (구현 후 활성화, opt-in)
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# Pro 사전 등록 이메일 수집 엔드포인트 (선택)
# NEXT_PUBLIC_WAITLIST_ENDPOINT=

# ─────────────────────────────────────────────────────────
# Pro (Phase A~C 도입 시)
# ─────────────────────────────────────────────────────────

# Supabase — 인증 + 클라우드 동기화
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=        # 서버 사이드만

# 토스페이먼츠 — 빌링
# TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=                   # 서버 사이드만

# Sentry — 에러 원격 전송 (opt-in)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=                 # 소스맵 업로드용
